{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build MiniOS Project",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-std=c++17",
                "main.cpp",
                "input.cpp",
                "logger.cpp",
                "memory.cpp",
                "resource.cpp",
                "scheduler.cpp",
                "simulation.cpp",
                "-o",
                "sim.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}
